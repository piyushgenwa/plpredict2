rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.is_admin == true;
    }

    // Profiles: any authenticated user can read, only own profile can write
    match /profiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Matches: any authenticated user can read, only admins can write
    match /matches/{matchId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // Predictions: any authenticated user can read, only own predictions can be written
    match /predictions/{predictionId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.data.user_id == request.auth.uid;
    }

    // API Logs: any authenticated user can write, only admins can read
    match /api_logs/{logId} {
      allow read: if request.auth != null && isAdmin();
      allow write: if request.auth != null;
    }

    // Settings: any authenticated user can read, only admins can write
    match /settings/{key} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }
  }
}
